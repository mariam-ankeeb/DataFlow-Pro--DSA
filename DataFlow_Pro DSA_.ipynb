   "source": [
    "---\n",
    "## Phase 2: The \"Applied Steps\" Tracker (Linked Lists)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "phase2-sll",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[History] Step added: 'Source'\n",
      "[History] Step added: 'Removed Nulls'\n",
      "[History] Step added: 'Changed Type'\n",
      "[History] Step added: 'Renamed Columns'\n",
      "[History] Step added: 'Filtered Rows'\n",
      "\n",
      "[History] Applied Steps:\n",
      "  Step 1: Source ->   Step 2: Removed Nulls ->   Step 3: Changed Type ->   Step 4: Renamed Columns ->   Step 5: Filtered Rows -> None\n",
      "\n",
      "[History] Total steps: 5\n"
     ]
    }
   ],
   "source": [
    "class StepNode:\n",
    "    \"\"\"A single node in our Singly Linked List.\"\"\"\n",
    "    def __init__(self, step_name):\n",
    "        self.step_name = step_name   \n",
    "        self.next = None            \n",
    "\n",
    "\n",
    "class StepHistory:\n",
    "    \"\"\"A Singly Linked List that stores Power Query transformation steps.\"\"\"\n",
    "\n",
    "    def __init__(self):\n",
    "        self.head = None   \n",
    "        self.size = 0\n",
    "\n",
    "    def add_step(self, step_name):\n",
    "        \"\"\"Adds a new step at the END of the list. O(n) — must traverse to find tail.\"\"\"\n",
    "        new_node = StepNode(step_name)\n",
    "        if self.head is None:\n",
    "            self.head = new_node\n",
    "        else:\n",
    "            current = self.head\n",
    "            while current.next:      \n",
    "                current = current.next\n",
    "            current.next = new_node   \n",
    "        self.size += 1\n",
    "        print(f\"[History] Step added: '{step_name}'\")\n",
    "\n",
    "    def display_steps(self):\n",
    "        \"\"\"Prints all steps in order. O(n).\"\"\"\n",
    "        if not self.head:\n",
    "            print(\"[History] No steps recorded yet.\")\n",
    "            return\n",
    "\n",
    "        print(\"[History] Applied Steps:\")\n",
    "        current = self.head\n",
    "        step_num = 1\n",
    "        while current:\n",
    "            print(f\"  Step {step_num}: {current.step_name} -> \", end=\"\")\n",
    "            current = current.next\n",
    "            step_num += 1\n",
    "        print(\"None\")\n",
    "history = StepHistory()\n",
    "history.add_step(\"Source\")\n",
    "history.add_step(\"Removed Nulls\")\n",
    "history.add_step(\"Changed Type\")\n",
    "history.add_step(\"Renamed Columns\")\n",
    "history.add_step(\"Filtered Rows\")\n",
    "\n",
    "print()\n",
    "history.display_steps()\n",
    "print(f\"\\n[History] Total steps: {history.size}\")"
   ]
  },
