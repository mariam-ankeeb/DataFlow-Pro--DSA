    "class LiveIngestionQueue:\n",
    "    \"\"\"\n",
    "    Production-grade buffer for live streaming NileMart POS data.\n",
    "    Uses collections.deque: O(1) enqueue AND dequeue.\n",
    "    C-level performance — handles White Friday traffic! \n",
    "    \"\"\"\n",
    "\n",
    "    def __init__(self):\n",
    "        self.buffer = deque()  \n",
    "\n",
    "    def enqueue_row(self, row_data: dict) -> None:\n",
    "        \"\"\"Adds a new row of live POS data to the back. O(1).\"\"\"\n",
    "        self.buffer.append(row_data)  \n",
    "        print(f\"[Buffer] Enqueued live data from POS: {row_data}\")\n",
    "\n",
    "    def process_batch(self, batch_size: int) -> list:\n",
    "        \"\"\"Removes batch_size items from front and returns them. O(k).\"\"\"\n",
    "        processed_data = []\n",
    "        for _ in range(batch_size):\n",
    "            if not self.buffer:                           \n",
    "                break\n",
    "            processed_data.append(self.buffer.popleft())  \n",
    "        print(f\"[Buffer] Processed {len(processed_data)} transactions. Pushing to NileMart Power BI Datasets...\")\n",
    "        return processed_data\n",
    "\n",
    "    def get_size(self):\n",
    "        return len(self.buffer)\n",
    "\n",
    "deque_q = deque()\n",
    "for i in range(N):\n",
    "    deque_q.append(i)\n",
    "\n",
    "start = time.time()\n",
    "while deque_q:\n",
    "    deque_q.popleft()\n",
    "deque_time = time.time() - start\n",
    "\n",
    "print(f\"[collections.deque] Dequeue {N:,} items: {deque_time:.4f}s | O(1) per op \")\n",
    "print(\"\\n\" + \"=\" * 55)\n",
