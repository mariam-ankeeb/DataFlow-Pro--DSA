   "source": [
    "sorted_txn_ids = sorted(txn_ids)\n",
    "fraud_target = sorted_txn_ids[7000]\n",
    "\n",
    "print(f\"[Lookup Engine] Searching for Fraudulent TXN ID: {fraud_target}\")\n",
    "print(\"-\" * 55)\n",
    "def linear_search(arr, target):\n",
    "    for index, value in enumerate(arr):\n",
    "        if value == target:\n",
    "            return index    \n",
    "    return -1               \n",
    "\n",
    "\n",
    "start = time.time()\n",
    "linear_idx = linear_search(txn_ids, fraud_target)  \n",
    "linear_time = time.time() - start\n",
    "print(f\"  Linear Search (unsorted): found at index {linear_idx} | Time: {linear_time:.6f}s | O(n)\")\n",
    "\n",
    "def binary_search(arr, target):\n",
    "    low  = 0\n",
    "    high = len(arr) - 1\n",
    "    while low <= high:\n",
    "        mid = (low + high) // 2     \n",
    "        if arr[mid] == target:      \n",
    "            return mid\n",
    "        elif arr[mid] < target:     \n",
    "            low = mid + 1\n",
    "        else:                       \n",
    "            high = mid - 1\n",
    "    return -1   \n",
    "\n",
    "start = time.time()\n",
    "binary_idx = binary_search(sorted_txn_ids, fraud_target)   \n",
    "binary_time = time.time() - start\n",
    "print(f\"  Binary Search (sorted)  : found at index {binary_idx} | Time: {binary_time:.6f}s | O(log n)\")\n",
    "if linear_time > 0 and binary_time > 0:\n",
    "    print(f\"\\n  [Speed-Up] Binary Search is ~{linear_time / binary_time:.0f}x faster than Linear Search\")"
   ]
