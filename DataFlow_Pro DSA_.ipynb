    "random.seed(42)\n",
    "\n",
    "def generate_transactions(n=10000):\n",
    "    \"\"\"\n",
    "    Generates a list of n fake transaction records.\n",
    "    Each record is a dictionary (like a row in a database table).\n",
    "    \"\"\"\n",
    "    branches = [\"Maadi\", \"Zayed\", \"Smouha\", \"Mansoura\", \"Heliopolis\", \"Aswan\"]\n",
    "    transactions = []\n",
    "    for i in range(n):\n",
    "        transactions.append({\n",
    "            \"txn_id\": random.randint(100000, 999999),   \n",
    "            \"branch\": random.choice(branches),          \n",
    "            \"amount_egp\": round(random.uniform(50, 15000), 2),  \n",
    "            \"month\": random.randint(1, 12)               \n",
    "        })\n",
    "    return transactions\n",
    "transactions = generate_transactions(10000)\n",
    "print(f\"[Indexer] Generated {len(transactions):,} transaction records.\")\n",
    "print(f\"[Indexer] Sample record: {transactions[0]}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "phase1-slow-sorts",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[Benchmark] Slow Sorts on 500 records...\n",
      "  Bubble Sort    : 0.0100s  | O(n²) |  Unacceptable for 10,000 rows\n",
      "  Insertion Sort : 0.0046s  | O(n²) |  Unacceptable for 10,000 rows\n",
      "  Selection Sort : 0.0067s  | O(n²) |  Unacceptable for 10,000 rows\n",
      "\n",
      "[Indexer] All three O(n²) sorts verified — they cannot scale to production! \n"
     ]
    }
   ],
   "source": [
    "def bubble_sort(data):\n",
    "    arr = [row[\"txn_id\"] for row in data]  \n",
    "    n = len(arr)\n",
    "    for i in range(n):\n",
    "        for j in range(0, n - i - 1):        \n",
    "            if arr[j] > arr[j + 1]:         \n",
    "                arr[j], arr[j + 1] = arr[j + 1], arr[j]\n",
    "    return arr\n",
    "\n",
    "\n",
    "def insertion_sort(data):\n",
    "    arr = [row[\"txn_id\"] for row in data]\n",
    "    for i in range(1, len(arr)):\n",
    "        key = arr[i]                        \n",
    "        j = i - 1\n",
    "        while j >= 0 and arr[j] > key:      \n",
    "            arr[j + 1] = arr[j]\n",
    "            j -= 1\n",
    "        arr[j + 1] = key                    \n",
    "    return arr\n",
    "def selection_sort(data):\n",
    "    arr = [row[\"txn_id\"] for row in data]\n",
    "    n = len(arr)\n",
    "    for i in range(n):\n",
    "        min_idx = i                           \n",
    "        for j in range(i + 1, n):            \n",
    "            if arr[j] < arr[min_idx]:\n",
    "                min_idx = j\n",
    "        arr[i], arr[min_idx] = arr[min_idx], arr[i] \n",
    "    return arr\n",
    "\n",
    "\n",
    "small_sample = transactions[:500]\n",
    "\n",
    "print(\"[Benchmark] Slow Sorts on 500 records...\")\n",
    "\n",
    "start = time.time()\n",
    "bubble_result = bubble_sort(small_sample)\n",
    "print(f\"  Bubble Sort    : {time.time() - start:.4f}s  | O(n²) |  Unacceptable for 10,000 rows\")\n",
    "\n",
    "start = time.time()\n",
    "insertion_result = insertion_sort(small_sample)\n",
    "print(f\"  Insertion Sort : {time.time() - start:.4f}s  | O(n²) |  Unacceptable for 10,000 rows\")\n",
    "\n",
    "start = time.time()\n",
    "selection_result = selection_sort(small_sample)\n",
    "print(f\"  Selection Sort : {time.time() - start:.4f}s  | O(n²) |  Unacceptable for 10,000 rows\")\n",
    "\n",
    "print(\"\\n[Indexer] All three O(n²) sorts verified — they cannot scale to production! \")"
   ]
  },
