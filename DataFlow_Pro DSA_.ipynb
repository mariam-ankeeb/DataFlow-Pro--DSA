    "class DAXEvaluator:\n",
    "    \"\"\"\n",
    "    Evaluates Postfix (Reverse Polish Notation) DAX-like expressions.\n",
    "\n",
    "    How Postfix works:\n",
    "        Infix  : (15000 + 5000) * 2\n",
    "        Postfix: 15000 5000 + 2 *\n",
    "\n",
    "    Algorithm:\n",
    "        - Read tokens left to right\n",
    "        - If number  => PUSH onto stack\n",
    "        - If operator => POP two operands, COMPUTE, PUSH result\n",
    "        - Final answer = only element left on stack\n",
    "    \"\"\"\n",
    "\n",
    "    def evaluate_postfix(self, expression: str) -> float:\n",
    "        \"\"\"Evaluates a postfix expression string. Returns numeric result.\"\"\"\n",
    "        stack  = ArrayStack()\n",
    "        tokens = expression.split()   \n",
    "\n",
    "        for token in tokens:\n",
    "            if self._is_number(token):\n",
    "                stack.push(float(token))\n",
    "            elif token in ('+', '-', '*', '/'):\n",
    "                if stack.get_size() < 2:\n",
    "                    print(\"[DAX] Error: Not enough operands!\")\n",
    "                    return None\n",
    "\n",
    "                b = stack.pop()   \n",
    "                a = stack.pop()   \n",
    "                if   token == '+':  stack.push(a + b)\n",
    "                elif token == '-':  stack.push(a - b)\n",
    "                elif token == '*':  stack.push(a * b)\n",
    "                elif token == '/':\n",
    "                    if b == 0:\n",
    "                        print(\"[DAX] Error: Division by zero!\")\n",
    "                        return None\n",
    "                    stack.push(a / b)\n",
    "            else:\n",
    "                print(f\"[DAX] Error: Unknown token '{token}'\")\n",
    "                return None\n",
    "        if stack.get_size() != 1:\n",
    "            print(\"[DAX] Error: Invalid expression!\")\n",
    "            return None\n",
    "\n",
    "        return stack.pop()\n",
    "\n",
    "    def check_parentheses(self, expression: str) -> bool:\n",
    "        \"\"\"\n",
    "        Validates that all parentheses in an infix expression are balanced.\n",
    "        Uses a Stack: push '(', pop on ')' — mismatch = error.\n",
    "        \"\"\"\n",
    "        stack = ArrayStack()\n",
    "        for char in expression:\n",
    "            if char == '(':\n",
    "                stack.push(char)          \n",
    "            elif char == ')':\n",
    "                if stack.is_empty():    \n",
    "                    return False\n",
    "                stack.pop()               \n",
    "        return stack.is_empty()       \n",
    "\n",
    "    def _is_number(self, token):\n",
    "        \"\"\"Helper: returns True if token can be parsed as a float.\"\"\"\n",
    "        try:\n",
    "            float(token)\n",
    "            return True\n",
    "        except ValueError:\n",
    "            return False\n",
    "\n",
    "\n",
    "dax = DAXEvaluator()\n",
    "expr1   = \"15000 5000 + 2 *\"\n",
    "result1 = dax.evaluate_postfix(expr1)\n",
    "print(f\"[DAX] '{expr1}' => {result1:,.0f} EGP\")\n",
    "expr2   = \"50000 30000 - 0.14 *\"\n",
    "result2 = dax.evaluate_postfix(expr2)\n",
    "print(f\"[DAX] '{expr2}' => {result2:,.2f} EGP  (NileMart Gross Profit Tax)\")\n",
    "expr3a = \"(Revenue - Cost) * (1 + Tax_Rate)\"\n",
    "expr3b = \"(Revenue - Cost) * (1 + Tax_Rate\"\n",
    "print(f\"\\n[DAX] Parentheses check '{expr3a}': {dax.check_parentheses(expr3a)} \")\n",
    "print(f\"[DAX] Parentheses check '{expr3b}': {dax.check_parentheses(expr3b)} \")"
   ]
