   "source": [
    "from anytree import Node, RenderTree\n",
    "\n",
    "class OrgChartAnalyzer:\n",
    "    \"\"\"\n",
    "    Uses anytree to model NileMart's corporate hierarchy.\n",
    "    Supports recursive Roll-Up sales aggregation (Post-Order traversal).\n",
    "    \"\"\"\n",
    "\n",
    "    def __init__(self):\n",
    "        self.ceo = Node(\"Omar (Global CEO)\", sales=0)\n",
    "        self.vp_cairo = Node(\"Tarek (VP Cairo & Giza)\",  parent=self.ceo, sales=0)\n",
    "        self.vp_alex  = Node(\"Salma (VP Alex & Delta)\",  parent=self.ceo, sales=0)\n",
    "        Node(\"Aya (Maadi Branch Rep)\",      parent=self.vp_cairo, sales=150000)\n",
    "        Node(\"Mahmoud (Zayed Branch Rep)\",  parent=self.vp_cairo, sales=270000)\n",
    "        Node(\"Kareem (Smouha Branch Rep)\",  parent=self.vp_alex,  sales=180000)\n",
    "        Node(\"Nour (Mansoura Branch Rep)\",  parent=self.vp_alex,  sales=120000)\n",
    "\n",
    "    def display_chart(self):\n",
    "        \"\"\"Prints the visual tree hierarchy using anytree's RenderTree.\"\"\"\n",
    "        print(\"\\n[Org Chart] NileMart Hierarchy:\")\n",
    "        for pre, _, node in RenderTree(self.ceo):\n",
    "            print(f\"{pre}{node.name} (Direct Sales: {node.sales:,} EGP)\")\n",
    "\n",
    "    def roll_up_sales(self, node: Node) -> int:\n",
    "        \"\"\"\n",
    "        Recursively calculates total sales for a manager by summing\n",
    "        their own sales + the sales of ALL their descendants.\n",
    "\n",
    "        Algorithm (Post-Order Traversal — process children before parent):\n",
    "            total = node.sales + sum(roll_up_sales(child) for each child)\n",
    "\n",
    "        Base Case: Leaf node (no children) → return node.sales directly\n",
    "        Recursive Case: sum own sales + recursively sum all children\n",
    "        \"\"\"\n",
    "        if not node.children:\n",
    "            return node.sales\n",
    "\n",
    "        total = node.sales\n",
    "        for child in node.children:\n",
    "            total += self.roll_up_sales(child)  \n",
    "        return total\n",
    "\n",
    "\n",
    "org_chart = OrgChartAnalyzer()\n",
    "org_chart.display_chart()\n",
    "\n",
    "print(\"\\n[Roll-Up] Calculating total revenue under each manager...\")\n",
    "tarek_total = org_chart.roll_up_sales(org_chart.vp_cairo)\n",
    "salma_total = org_chart.roll_up_sales(org_chart.vp_alex)\n",
    "ceo_total   = org_chart.roll_up_sales(org_chart.ceo)\n",
    "\n",
    "print(f\"  Tarek (VP Cairo & Giza) total: {tarek_total:>12,} EGP\")\n",
    "print(f\"  Salma (VP Alex & Delta) total: {salma_total:>12,} EGP\")\n",
    "print(f\"  Omar  (Global CEO)      total: {ceo_total:>12,} EGP\")\n",
    "print(f\"\\n[Insight] CEO total = Cairo region + Alex region = {tarek_total:,} + {salma_total:,} = {ceo_total:,} EGP \")"
   ]
