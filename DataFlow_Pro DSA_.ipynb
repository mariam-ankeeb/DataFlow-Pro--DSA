    "class StackNode:\n",
    "    \"\"\"A node in our Linked List Stack.\"\"\"\n",
    "    def __init__(self, value):\n",
    "        self.value = value\n",
    "        self.next = None    \n",
    "\n",
    "\n",
    "class LinkedListStack:\n",
    "    \"\"\"Stack built on Singly Linked List. All operations O(1).\"\"\"\n",
    "\n",
    "    def __init__(self):\n",
    "        self.top  = None   \n",
    "        self.size = 0\n",
    "\n",
    "    def push(self, value):\n",
    "        \"\"\"Create new node and place at top. O(1).\"\"\"\n",
    "        new_node = StackNode(value)\n",
    "        new_node.next = self.top   \n",
    "        self.top = new_node        \n",
    "        self.size += 1\n",
    "\n",
    "    def pop(self):\n",
    "        \"\"\"Remove top node and return its value. O(1).\"\"\"\n",
    "        if self.is_empty():\n",
    "            print(\"[Stack] Underflow — stack is empty!\")\n",
    "            return None\n",
    "        value    = self.top.value\n",
    "        self.top = self.top.next  \n",
    "        self.size -= 1\n",
    "        return value\n",
    "\n",
    "    def peek(self):\n",
    "        \"\"\"View top value without removing. O(1).\"\"\"\n",
    "        if self.is_empty():\n",
    "            return None\n",
    "        return self.top.value\n",
    "\n",
    "    def is_empty(self):\n",
    "        return self.size == 0\n",
    "\n",
    "    def get_size(self):\n",
    "        return self.size\n",
    "\n",
    "    def print_stack(self):\n",
    "        if self.is_empty():\n",
    "            print(\"[Stack] Empty\")\n",
    "            return\n",
    "        current = self.top\n",
    "        print(\"Stack Data (top → bottom):\")\n",
    "        while current:\n",
    "            print(f\"  {current.value}\")\n",
    "            current = current.next\n",
    "\n",
    "ll_stack = LinkedListStack()\n",
    "ll_stack.push(10)\n",
    "ll_stack.push(20)\n",
    "ll_stack.push(50)\n",
    "ll_stack.print_stack()\n",
    "print(f\"Top: {ll_stack.peek()} | Size: {ll_stack.get_size()}\")\n",
    "ll_stack.pop()\n",
    "ll_stack.print_stack()\n",
    "print(f\"Top after pop: {ll_stack.peek()}\")"
   ]
  },
