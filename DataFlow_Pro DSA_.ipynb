    "class ArrayStack:\n",
    "    \"\"\"Stack implemented using a Python list. All operations O(1).\"\"\"\n",
    "\n",
    "    def __init__(self):\n",
    "        self._data = []   \n",
    "\n",
    "    def push(self, value):\n",
    "        \"\"\"Add a new item on top. O(1).\"\"\"\n",
    "        self._data.append(value)\n",
    "\n",
    "    def pop(self):\n",
    "        \"\"\"Remove and return the top item. O(1).\"\"\"\n",
    "        if self.is_empty():\n",
    "            print(\"[Stack] Underflow — stack is empty!\")\n",
