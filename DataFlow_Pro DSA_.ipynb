    "class ListQueue:\n",
    "    \"\"\"\n",
    "    Queue using a plain Python list.\n",
    "    Problem: dequeue uses list.pop(0) which is O(n) — shifts ALL elements!\n",
    "    Imagine 1 million rows on White Friday... \n",
    "    \"\"\"\n",
    "\n",
    "    def __init__(self):\n",
    "        self._data = []  \n",
    "\n",
    "    def enqueue(self, item):\n",
    "        \"\"\"Add to back. O(1) amortized.\"\"\"\n",
    "        self._data.append(item)\n",
    "\n",
    "    def dequeue(self):\n",
    "        \"\"\"Remove from front. O(n) — shifts all remaining elements!\"\"\"\n",
    "        if self.is_empty():\n",
    "            return \"Queue Underflow\"\n",
    "        return self._data.pop(0)   \n",
    "\n",
    "    def is_empty(self):\n",
    "        return len(self._data) == 0\n",
    "\n",
    "    def get_size(self):\n",
    "        return len(self._data)\n",
    "N = 100000\n",
    "\n",
    "list_q = ListQueue()\n",
    "for i in range(N):\n",
    "    list_q.enqueue(i)\n",
    "start = time.time()\n",
    "while not list_q.is_empty():\n",
    "    list_q.dequeue()\n",
    "list_time = time.time() - start\n",
    "\n",
    "print(f\"[ListQueue]  Dequeue {N:,} items: {list_time:.4f}s | O(n) per dequeue ")"
   ]
