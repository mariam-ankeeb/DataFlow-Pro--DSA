    "class QueueNode:\n",
    "    def __init__(self, data):\n",
    "        self.data = data\n",
    "        self.next = None\n",
    "\n",
    "\n",
    "class LinkedListQueue:\n",
    "    \"\"\"\n",
    "    Queue using Singly Linked List.\n",
    "    Enqueue at REAR: O(1)\n",
    "    Dequeue at FRONT: O(1) ← No shifting!\n",
    "    \"\"\"\n",
    "\n",
    "    def __init__(self):\n",
    "        self.front = None   \n",
    "        self.rear  = None   \n",
    "        self.size  = 0\n",
    "\n",
    "    def enqueue(self, data):\n",
    "        \"\"\"Add new node at rear. O(1).\"\"\"\n",
    "        new_node = QueueNode(data)\n",
    "\n",
    "        if self.rear is None:\n",
    "            self.front = self.rear = new_node\n",
    "        else:\n",
    "            self.rear.next = new_node  \n",
    "            self.rear      = new_node   \n",
    "        self.size += 1\n",
    "\n",
    "    def dequeue(self):\n",
    "        \"\"\"Remove and return front node. O(1) — no shifting!\"\"\"\n",
    "        if self.front is None:\n",
    "            return \"Queue Underflow\"\n",
    "        removed_node = self.front\n",
    "        self.front   = removed_node.next   \n",
    "        if self.front is None:           \n",
    "            self.rear = None\n",
    "        self.size -= 1\n",
    "        return removed_node.data\n",
    "\n",
    "    def is_empty(self):\n",
    "        return self.front is None\n",
    "\n",
    "    def get_size(self):\n",
    "        return self.size\n",
    "\n",
    "\n",
    "ll_q = LinkedListQueue()\n",
    "for i in range(N):\n",
    "    ll_q.enqueue(i)\n",
    "\n",
    "start = time.time()\n",
    "while not ll_q.is_empty():\n",
    "    ll_q.dequeue()\n",
    "ll_time = time.time() - start\n",
    "print(f\"[LinkedListQueue] Dequeue {N:,} items: {ll_time:.4f}s | O(1) per dequeue ")"
   ]
  },
