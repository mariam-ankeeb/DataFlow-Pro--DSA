    "etl_tracker = AppliedStepsTracker()\n",
    "etl_tracker.add_step(\"Source\")\n",
    "etl_tracker.add_step(\"Removed Nulls\")\n",
    "etl_tracker.add_step(\"Renamed Columns\")\n",
    "etl_tracker.undo()\n",
