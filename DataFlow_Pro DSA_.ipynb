   "id": "phase2-dll",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[Tracker] Step added: 'Source' | Current: 'Source'\n",
      "[Tracker] Step added: 'Removed Nulls' | Current: 'Removed Nulls'\n",
      "[Tracker] Step added: 'Changed Type' | Current: 'Changed Type'\n",
      "[Tracker] Step added: 'Renamed Columns' | Current: 'Renamed Columns'\n",
      "\n",
      "[Tracker] Steps (forward): 'Source' <-> 'Removed Nulls' <-> 'Changed Type' <-> 'Renamed Columns' ← CURRENT\n",
      "\n",
      "[Tracker] ↩ Undo → Current step: 'Changed Type'\n",
      "[Tracker] ↩ Undo → Current step: 'Removed Nulls'\n",
      "[Tracker] Steps (forward): 'Source' <-> 'Removed Nulls' ← CURRENT <-> 'Changed Type' <-> 'Renamed Columns'\n",
      "\n",
      "[Tracker] ↪ Redo → Current step: 'Changed Type'\n",
      "[Tracker] Steps (forward): 'Source' <-> 'Removed Nulls' <-> 'Changed Type' ← CURRENT <-> 'Renamed Columns'\n",
      "\n",
      "[Tracker] Steps (backward): 'Renamed Columns' <-> 'Changed Type' <-> 'Removed Nulls' <-> 'Source'\n"
     ]
    }
   ],
   "source": [
    "class DoubleStepNode:\n",
    "    \"\"\"A node in our Doubly Linked List — has both next and prev pointers.\"\"\"\n",
    "    def __init__(self, step_name):\n",
    "        self.step_name = step_name\n",
    "        self.next = None   \n",
    "        self.prev = None   \n",
    "\n",
    "\n",
    "class AppliedStepsTracker:\n",
    "    \"\"\"Doubly Linked List tracker — supports O(1) Undo and Redo.\"\"\"\n",
    "\n",
    "    def __init__(self):\n",
    "        self.head    = None   \n",
    "        self.tail    = None   \n",
    "        self.current = None   \n",
    "        self.size    = 0\n",
    "\n",
    "    def add_step(self, step_name):\n",
    "        \"\"\"Adds a new step at the tail. O(1) — tail pointer makes this instant!\"\"\"\n",
    "        new_node = DoubleStepNode(step_name)\n",
    "        if not self.head:\n",
    "            self.head = new_node\n",
    "            self.tail = new_node\n",
    "        else:\n",
    "            new_node.prev  = self.tail    \n",
    "            self.tail.next = new_node    \n",
    "            self.tail      = new_node     \n",
    "        self.current = new_node   \n",
    "        self.size += 1\n",
    "        print(f\"[Tracker] Step added: '{step_name}' | Current: '{self.current.step_name}'\")\n",
    "\n",
    "    def undo(self):\n",
    "        \"\"\"Move current pointer one step back. O(1) — just follow prev pointer!\"\"\"\n",
    "        if not self.current or not self.current.prev:\n",
    "            print(\"[Tracker] Undo: Already at first step — cannot go back.\")\n",
    "            return\n",
    "        self.current = self.current.prev  \n",
    "        print(f\"[Tracker] ↩ Undo → Current step: '{self.current.step_name}'\")\n",
    "\n",
    "    def redo(self):\n",
    "        \"\"\"Move current pointer one step forward. O(1) — just follow next pointer!\"\"\"\n",
    "        if not self.current or not self.current.next:\n",
    "            print(\"[Tracker] Redo: Already at last step — cannot go forward.\")\n",
    "            return\n",
    "        self.current = self.current.next   \n",
    "        print(f\"[Tracker] ↪ Redo → Current step: '{self.current.step_name}'\")\n",
    "\n",
    "    def display_forward(self):\n",
    "        \"\"\"Prints all steps from head to tail, marking the current step.\"\"\"\n",
    "        if not self.head:\n",
    "            print(\"[Tracker] No steps recorded.\")\n",
    "            return\n",
    "        print(\"[Tracker] Steps (forward): \", end=\"\")\n",
    "        current = self.head\n",
    "        while current:\n",
    "            marker = \" ← CURRENT\" if current == self.current else \"\"\n",
    "            print(f\"'{current.step_name}'{marker}\", end=\" <-> \" if current.next else \"\\n\")\n",
    "            current = current.next\n",
    "\n",
    "    def display_backward(self):\n",
    "        \"\"\"Prints all steps from tail to head (reverse order) — proves prev pointers work!\"\"\"\n",
    "        if not self.tail:\n",
    "            print(\"[Tracker] No steps recorded.\")\n",
    "            return\n",
    "        print(\"[Tracker] Steps (backward): \", end=\"\")\n",
    "        current = self.tail\n",
    "        while current:\n",
    "            print(f\"'{current.step_name}'\", end=\" <-> \" if current.prev else \"\\n\")\n",
    "            current = current.prev\n",
    "\n",
    "tracker = AppliedStepsTracker()\n",
    "tracker.add_step(\"Source\")\n",
    "tracker.add_step(\"Removed Nulls\")\n",
    "tracker.add_step(\"Changed Type\")\n",
    "tracker.add_step(\"Renamed Columns\")\n",
    "print()\n",
    "tracker.display_forward()\n",
    "print()\n",
    "tracker.undo()\n",
    "tracker.undo()\n",
    "tracker.display_forward()\n",
    "print()\n",
    "tracker.redo()\n",
    "tracker.display_forward()\n",
    "print()\n",
    "tracker.display_backward()"
   ]
  },
