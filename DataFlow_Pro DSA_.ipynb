    "class BSTNode:\n",
    "    \"\"\"A node in our Binary Search Tree.\"\"\"\n",
    "    def __init__(self, national_id: int, name: str):\n",
    "        self.national_id = national_id   \n",
    "        self.name        = name         \n",
    "        self.left        = None          \n",
    "        self.right       = None         \n",
    "\n",
    "\n",
    "class DimensionIndex:\n",
    "    \"\"\"\n",
    "    Binary Search Tree to store unique Customer National IDs.\n",
    "    Mimics how Power BI compresses dimension tables for fast relationships.\n",
    "    \"\"\"\n",
    "\n",
    "    def __init__(self):\n",
    "        self.root = None  \n",
    "\n",
    "    def insert(self, national_id: int, name: str) -> None:\n",
    "        \"\"\"Insert a new customer into the BST. O(log n) average.\"\"\"\n",
    "        new_node = BSTNode(national_id, name)\n",
    "\n",
    "        if self.root is None:\n",
    "            self.root = new_node\n",
    "            return\n",
    "        current = self.root\n",
    "        while True:\n",
    "            if national_id < current.national_id:      \n",
    "                if current.left is None:\n",
    "                    current.left = new_node\n",
    "                    return\n",
    "                current = current.left\n",
    "\n",
    "            elif national_id > current.national_id:     \n",
    "                if current.right is None:\n",
    "                    current.right = new_node        \n",
    "                    return\n",
    "                current = current.right\n",
    "\n",
    "            else:                                      \n",
    "                print(f\"[BST] ID {national_id} already exists.\")\n",
    "                return\n",
    "\n",
    "    def search(self, national_id: int) -> str:\n",
    "        \"\"\"\n",
    "        Search for a customer by National ID. O(log n) average.\n",
    "        Returns customer name or None if not found.\n",
    "        \"\"\"\n",
    "        current = self.root\n",
    "\n",
    "        while current:\n",
    "            if national_id == current.national_id:  \n",
    "                return current.name\n",
    "            elif national_id < current.national_id: \n",
    "                current = current.left\n",
    "            else:                                     \n",
    "                current = current.right\n",
    "        return None   \n",
    "\n",
    "    def inorder_traversal(self):\n",
    "        \"\"\"Returns all customers in ascending order of National ID. O(n).\"\"\"\n",
    "        result = []\n",
    "        self._inorder(self.root, result)\n",
    "        return result\n",
    "\n",
    "    def _inorder(self, node, result):\n",
    "        \"\"\"Helper: Left → Root → Right traversal.\"\"\"\n",
    "        if node:\n",
    "            self._inorder(node.left, result)              \n",
    "            result.append((node.national_id, node.name)) \n",
    "            self._inorder(node.right, result)            \n",
    "\n",
    "\n",
    "dimension_index = DimensionIndex()\n",
    "customers = [\n",
    "    (29901151234567, \"Ahmed Hassan\"),\n",
    "    (30005201234568, \"Sara Mohamed\"),\n",
    "    (29801101234569, \"Omar Khaled\"),\n",
    "    (30102281234560, \"Nour Ali\"),\n",
    "    (29712151234561, \"Mahmoud Saad\"),\n",
    "    (30208051234562, \"Aya Tarek\"),\n",
    "]\n",
    "\n",
    "print(\"[DimensionIndex] Inserting NileMart customers...\")\n",
    "for nid, name in customers:\n",
    "    dimension_index.insert(nid, name)\n",
    "    print(f\"  Inserted: {nid} → {name}\")\n",
    "\n",
    "print(\"\\n[DimensionIndex] Lookup tests:\")\n",
    "target_id = 30005201234568\n",
    "found = dimension_index.search(target_id)\n",
    "print(f\"  Search {target_id}: {found}  \" if found else f\"  Search {target_id}: Not Found \")\n",
    "\n",
