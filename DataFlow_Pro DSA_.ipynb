    "kpi_result = dax_engine.evaluate_postfix(\"120000 80000 - 0.25 *\")\n",
    "print(f\"[Phase 3] Gross Profit KPI: {kpi_result:,.2f} EGP\")\n",
    "\n",
    "# --- Phase 4: Live Buffer ---\n",
    "print(\"\\n[Phase 4] Ingesting live White Friday POS stream...\")\n",
    "live_buffer = LiveIngestionQueue()\n",
    "for i in range(5):\n",
    "    live_buffer.enqueue_row({\"txn\": 2000 + i, \"branch\": \"Maadi\", \"amt_egp\": 500 * (i + 1)})\n",
    "live_buffer.process_batch(3)\n",
    "print(f\"[Phase 4] Remaining in buffer: {live_buffer.get_size()} records\")\n",
    "\n",
